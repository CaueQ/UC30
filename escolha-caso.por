programa{
    funcao inicio() {
        inteiro opcao

        escreva("1-listar")
        escreva("2-cadastrar")
        leia(opcao)

        escreva(opcao) {

            caso 1:
            escreva("listar")
            pare

            caso 2:
            escreva("cadastrar")
            pare

            caso contrario:
            escreva("nenhuma opcao selecionada")
            pare
        }
    }
}